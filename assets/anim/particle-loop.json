{
  "name": "particle-loop",
  "description": "Animasi partikel peringatan mengambang naik di sekitar ilustrasi otak, loop tak terbatas.",
  "keyframes": [
    { "time": 0.0,  "opacity": 0,    "translateY": 0,    "scale": 1.0 },
    { "time": 0.2,  "opacity": 0.18, "translateY": -30,  "scale": 1.1 },
    { "time": 0.8,  "opacity": 0.06, "translateY": -120, "scale": 1.5 },
    { "time": 1.0,  "opacity": 0,    "translateY": -180, "scale": 2.0 }
  ],
  "duration": 7,
  "easing": "ease-in-out",
  "loop": true
}
